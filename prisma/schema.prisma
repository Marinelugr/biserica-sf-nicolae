generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Biblia Ortodoxă ─────────────────────────────────────────────────────────

model BibleBook {
  id       String         @id @default(cuid())
  slug     String         @unique
  nameRo   String
  nameRu   String
  nameEn   String
  testament String
  orderNum Int
  chapters BibleChapter[]
}

model BibleChapter {
  id         String       @id @default(cuid())
  bookId     String
  book       BibleBook    @relation(fields: [bookId], references: [id])
  chapterNum Int
  verses     BibleVerse[]
}

model BibleVerse {
  id        String       @id @default(cuid())
  chapterId String
  chapter   BibleChapter @relation(fields: [chapterId], references: [id])
  verseNum  Int
  textRo    String       @db.Text
  textRu    String?      @db.Text
  textEn    String?      @db.Text
}

// ─── Sfinți ──────────────────────────────────────────────────────────────────

model Saint {
  id        String  @id @default(cuid())
  month     Int
  day       Int
  nameRo    String
  nameRu    String?
  nameEn    String?
  slug      String  @unique
  lifeRo    String? @db.Text
  lifeRu    String? @db.Text
  lifeEn    String? @db.Text
  iconUrl   String?
  feastType String?

  @@index([month, day])
}

// ─── Rugăciuni ────────────────────────────────────────────────────────────────

model Prayer {
  id        String   @id @default(cuid())
  slug      String   @unique
  titleRo   String
  titleRu   String?
  titleEn   String?
  type      String
  textRo    String   @db.Text
  textRu    String?  @db.Text
  textEn    String?  @db.Text
  author    String?
  createdAt DateTime @default(now())
}

// ─── Articole / Știri ────────────────────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  titleRo     String
  titleRu     String?
  titleEn     String?
  contentRo   String    @db.Text
  contentRu   String?   @db.Text
  contentEn   String?   @db.Text
  category    String?
  imageUrl    String?
  metaDescRo  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

// ─── Biblioteca Ortodoxă ─────────────────────────────────────────────────────

model BookCategory {
  id        String        @id @default(cuid())
  name      String
  emoji     String        @default("📖")
  color     String        @default("#C9A84C")
  order     Int           @default(0)
  books     LibraryBook[]
  createdAt DateTime      @default(now())
}

model LibraryBook {
  id         String        @id @default(cuid())
  slug       String        @unique
  titleRo    String
  titleRu    String?
  titleEn    String?
  type       String
  categoryId String?
  category   BookCategory? @relation(fields: [categoryId], references: [id])
  contentRo  String        @db.Text
  contentRu  String?       @db.Text
  contentEn  String?       @db.Text
  author       String?
  source       String?
  imageUrl     String?
  galleryUrls  String[]
  videoUrl     String?
  videoTitle   String?
  ordine       Int           @default(0)
  createdAt    DateTime      @default(now())
}

// ─── Program Slujbe ──────────────────────────────────────────────────────────

model ServiceSchedule {
  id        String  @id @default(cuid())
  year      Int
  month     Int
  day       Int
  time      String
  serviceRo String
  serviceRu String?
  notes     String?

  @@index([year, month, day])
}

// ─── Magazin ─────────────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameRo        String
  price         Decimal  @db.Decimal(10, 2)
  descriptionRo String?  @db.Text
  imageUrl      String?
  stock         Int      @default(0)
  category      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─── Video ───────────────────────────────────────────────────────────────────

model VideoCategory {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  videos    Video[]
  createdAt DateTime @default(now())
}

model Video {
  id          String         @id @default(cuid())
  title       String
  url         String
  platform    String         @default("youtube")
  videoId     String
  categoryId  String?
  category    VideoCategory? @relation(fields: [categoryId], references: [id])
  description String?        @db.Text
  order       Int            @default(0)
  startTime   Int?
  endTime     Int?
  isLive      Boolean        @default(false)
  archivedAt  DateTime?
  serviceType String?
  createdAt   DateTime       @default(now())

  @@index([categoryId])
}

// ─── Setări globale ──────────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String @db.Text
}

// ─── Homepage Widgets ────────────────────────────────────────────────────────

model HomepageWidget {
  id      String  @id @default(cuid())
  section String  @unique
  enabled Boolean @default(true)
  order   Int
  config  Json?
}

// ─── Galerie media ────────────────────────────────────────────────────────────

model MediaItem {
  id           String   @id @default(cuid())
  url          String
  thumbnailUrl String?
  caption      String?
  order        Int      @default(0)
  entityType   String
  entityId     String
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
}

// ─── Preot paroh ─────────────────────────────────────────────────────────────

model Priest {
  id        String  @id @default(cuid())
  nameRo    String
  nameRu    String?
  nameEn    String?
  titleRo   String
  photoUrl  String?
  bioRo     String? @db.Text
  bioRu     String? @db.Text
  bioEn     String? @db.Text
  ordained  String?
  parish    String?
  education String? @db.Text
  phone     String?
  email     String?
  facebook  String?
  createdAt DateTime @default(now())
}
